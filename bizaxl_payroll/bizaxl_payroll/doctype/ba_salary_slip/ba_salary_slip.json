{
 "name": "BA Salary Slip",
 "doctype": "DocType",
 "module": "BizAxl Payroll",
 "naming_rule": "By \"Naming Series\" field",
 "autoname": "naming_series",
 "is_submittable": 1,
 "track_changes": 1,
 "fields": [
  {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "BA-SAL-.YYYY.-", "reqd": 1},
  {"fieldname": "employee", "fieldtype": "Link", "label": "Employee", "options": "BA Employee", "reqd": 1, "in_list_view": 1},
  {"fieldname": "employee_name", "fieldtype": "Data", "label": "Employee Name", "fetch_from": "employee.employee_name", "read_only": 1, "in_list_view": 1},
  {"fieldname": "department", "fieldtype": "Link", "label": "Department", "options": "BA Department", "fetch_from": "employee.department", "read_only": 1},
  {"fieldname": "designation", "fieldtype": "Link", "label": "Designation", "options": "BA Designation", "fetch_from": "employee.designation", "read_only": 1},
  {"fieldname": "col1", "fieldtype": "Column Break"},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "BA Company", "reqd": 1},
  {"fieldname": "salary_structure", "fieldtype": "Link", "label": "Salary Structure", "options": "BA Salary Structure"},
  {"fieldname": "payroll_entry", "fieldtype": "Link", "label": "Payroll Entry", "options": "BA Payroll Entry"},
  {"fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "BA Currency"},
  {"fieldname": "sec_period", "fieldtype": "Section Break", "label": "Payroll Period"},
  {"fieldname": "start_date", "fieldtype": "Date", "label": "Start Date", "reqd": 1},
  {"fieldname": "end_date", "fieldtype": "Date", "label": "End Date", "reqd": 1},
  {"fieldname": "posting_date", "fieldtype": "Date", "label": "Posting Date", "reqd": 1, "default": "Today"},
  {"fieldname": "col2", "fieldtype": "Column Break"},
  {"fieldname": "payment_days", "fieldtype": "Float", "label": "Payment Days"},
  {"fieldname": "working_days", "fieldtype": "Float", "label": "Working Days"},
  {"fieldname": "sec_earnings", "fieldtype": "Section Break", "label": "Earnings"},
  {"fieldname": "earnings", "fieldtype": "Table", "label": "Earnings", "options": "BA Salary Slip Earning"},
  {"fieldname": "sec_deductions", "fieldtype": "Section Break", "label": "Deductions"},
  {"fieldname": "deductions", "fieldtype": "Table", "label": "Deductions", "options": "BA Salary Slip Deduction"},
  {"fieldname": "sec_totals", "fieldtype": "Section Break", "label": "Totals"},
  {"fieldname": "gross_pay", "fieldtype": "Currency", "label": "Gross Pay", "read_only": 1},
  {"fieldname": "total_deductions", "fieldtype": "Currency", "label": "Total Deductions", "read_only": 1},
  {"fieldname": "net_pay", "fieldtype": "Currency", "label": "Net Pay", "read_only": 1, "in_list_view": 1},
  {"fieldname": "col3", "fieldtype": "Column Break"},
  {"fieldname": "base_salary", "fieldtype": "Currency", "label": "Base Salary", "read_only": 1},
  {"fieldname": "sec_account", "fieldtype": "Section Break", "label": "Accounting"},
  {"fieldname": "salary_payable_account", "fieldtype": "Link", "label": "Salary Payable Account", "options": "BA Account"},
  {"fieldname": "salary_expense_account", "fieldtype": "Link", "label": "Salary Expense Account", "options": "BA Account"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Draft\nSubmitted\nCancelled\nPaid", "read_only": 1},
  {"fieldname": "remarks", "fieldtype": "Small Text", "label": "Remarks"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1, "delete": 1},
  {"role": "HR Manager", "read": 1, "write": 1, "create": 1, "submit": 1, "cancel": 1},
  {"role": "HR User", "read": 1, "write": 1, "create": 1}
 ]
}
