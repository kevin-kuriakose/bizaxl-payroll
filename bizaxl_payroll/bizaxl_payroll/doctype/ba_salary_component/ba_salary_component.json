{
 "name": "BA Salary Component",
 "doctype": "DocType",
 "module": "BizAxl Payroll",
 "naming_rule": "By fieldname",
 "autoname": "field:component_name",
 "fields": [
  {"fieldname": "component_name", "fieldtype": "Data", "label": "Component Name", "reqd": 1, "unique": 1},
  {"fieldname": "component_type", "fieldtype": "Select", "label": "Type", "options": "Earning\nDeduction", "reqd": 1, "in_list_view": 1},
  {"fieldname": "col1", "fieldtype": "Column Break"},
  {"fieldname": "abbr", "fieldtype": "Data", "label": "Abbreviation", "reqd": 1},
  {"fieldname": "is_tax", "fieldtype": "Check", "label": "Is Tax Component"},
  {"fieldname": "sec_account", "fieldtype": "Section Break", "label": "Accounting"},
  {"fieldname": "account", "fieldtype": "Link", "label": "Account", "options": "BA Account"},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "BA Company"},
  {"fieldname": "sec_desc", "fieldtype": "Section Break", "label": "Description"},
  {"fieldname": "description", "fieldtype": "Small Text", "label": "Description"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "HR Manager", "read": 1, "write": 1, "create": 1},
  {"role": "HR User", "read": 1}
 ]
}
